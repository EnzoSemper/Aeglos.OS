template <class CharT, class Traits>
bool regex_search(const std::basic_string<CharT, Traits>& s, match_results<typename std::basic_string<CharT, Traits>::const_iterator>& m, const basic_regex<CharT, Traits>& e, regex_constants::match_flag_type f = regex_constants::match_default) {
    return false;
}

template <class CharT, class Traits>
bool regex_match(const std::basic_string<CharT, Traits>& s, const basic_regex<CharT, Traits>& e, regex_constants::match_flag_type f = regex_constants::match_default) {
    return false;
}
template <class CharT, class Traits>
bool regex_match(const std::basic_string<CharT, Traits>& s, match_results<typename std::basic_string<CharT, Traits>::const_iterator>& m, const basic_regex<CharT, Traits>& e, regex_constants::match_flag_type f = regex_constants::match_default) {
    return false;
}

// Regex Iterator
template<class BidiIter, class CharT = typename std::iterator_traits<BidiIter>::value_type, class Traits = std::char_traits<CharT>>
class regex_iterator {
public:
    regex_iterator() {}
    regex_iterator(BidiIter a, BidiIter b, const basic_regex<CharT, Traits>& re, regex_constants::match_flag_type m = regex_constants::match_default) {}

    bool operator==(const regex_iterator&) const { return true; }
    bool operator!=(const regex_iterator&) const { return false; }
    const match_results<BidiIter>& operator*() const { static match_results<BidiIter> d; return d; }
    const match_results<BidiIter>* operator->() const { static match_results<BidiIter> d; return &d; }
    regex_iterator& operator++() { return *this; }
    regex_iterator operator++(int) { return *this; }
};

using sregex_iterator = regex_iterator<std::string::const_iterator>;
using cregex_iterator = regex_iterator<const char*>;
using wsregex_iterator = regex_iterator<std::wstring::const_iterator>;

template <class CharT, class Traits>
std::basic_string<CharT, Traits> regex_replace(const std::basic_string<CharT, Traits>& s, const basic_regex<CharT, Traits>& e, const CharT* fmt, regex_constants::match_flag_type f = regex_constants::match_default) {
    return s;
}

template <class CharT, class Traits>
std::basic_string<CharT, Traits> regex_replace(const std::basic_string<CharT, Traits>& s, const basic_regex<CharT, Traits>& e, const std::basic_string<CharT, Traits>& fmt, regex_constants::match_flag_type f = regex_constants::match_default) {
    return s;
}

template <class CharT, class Traits = std::char_traits<CharT>>
std::basic_string<CharT, Traits> regex_replace(const CharT* s, const basic_regex<CharT, Traits>& e, const CharT* fmt, regex_constants::match_flag_type f = regex_constants::match_default) {
    return s ? std::basic_string<CharT, Traits>(s) : std::basic_string<CharT, Traits>();
}

